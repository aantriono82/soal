{
  "name": "assessment-ai-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:api": "bun --hot apps/api/src/index.ts",
    "dev:web": "bunx vite --config apps/web/vite.config.ts --host 0.0.0.0 --port 3000",
    "test": "bun test",
    "lint": "eslint apps/web/src/pages/auth-page.tsx packages/shared/schemas.ts packages/shared/types.ts scripts/dev.ts scripts/dev-runner.ts apps/api/src/app.ts apps/api/src/index.ts apps/web/vite.config.ts packages/shared/schemas.test.ts apps/api/src/app.test.ts apps/web/vite.config.test.ts scripts/dev-runner.test.ts",
    "build": "bun run build:web && bun run build:api",
    "build:web": "bunx vite build --config apps/web/vite.config.ts",
    "build:api": "bun build apps/api/src/index.ts --outdir dist/api --target bun",
    "build:seed": "bun build apps/api/src/db/seed.ts --outdir dist/api --target bun",
    "db:seed": "bun run apps/api/src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.821.0",
    "@hono/node-server": "^1.14.1",
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.80.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.5",
    "lucide-react": "^0.523.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "react-router-dom": "^7.6.2",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.2.21",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.3.5"
  }
}
